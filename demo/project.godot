[layer_names]

2d_render/layer_1="World"
2d_render/layer_2="Player"
2d_render/layer_3="NPC"
2d_render/layer_4="Foreground"
2d_render/layer_5="UI_Background"
2d_render/layer_6="UI"
2d_render/layer_7="Dialogue"
2d_render/layer_8="Notification"
2d_render/layer_9="Transition"
2d_render/layer_10="Debug"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

textures/canvas_textures/default_texture_filter=0
rendering_device/driver.windows="d3d12"
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
textures/filter=0
