[gd_resource type="Resource" script_class="DialogueData" load_steps=2 format=3]

[ext_resource type="Script" path="res://core/resources/dialogue_data.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
dialogue_id = &"dlg_ch1_chapter_end"
first_node = "intro"
nodes = [{
"node_id": "intro",
"speaker": "narrator",
"portrait": "normal",
"text": "第 7 天。\n一周过去了。\n\n你活下来了。\n\n钱包 ¥530\n体重没变\n心情 +20",
"next_node": "summary",
"effects": [
{"type": "set_flag", "flag_id": "chapter_1_done", "value": true}
]
}, {
"node_id": "summary",
"speaker": "narrator",
"portrait": "normal",
"text": "第一章 完。\n\n下一章：立足。\n\n第 8-30 天，找到稳定住所，认识更多人。",
"choices": [
{"text": "继续", "next_node": "end"}
]
}, {
"node_id": "end",
"speaker": "narrator",
"portrait": "normal",
"text": "（继续旅程…）"
}]
auto_close_on_end = true
