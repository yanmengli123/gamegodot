[gd_resource type="Resource" script_class="DialogueData" load_steps=2 format=3]

[ext_resource type="Script" path="res://core/resources/dialogue_data.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
dialogue_id = &"dlg_ch3_celebrate"
first_node = "intro"
nodes = [{
"node_id": "intro",
"speaker": "narrator",
"portrait": "normal",
"text": "第 80 天。\n你请王阿姨、李哥、小美吃饭。\n\n王阿姨：「小伙子出息了！」\n李哥：「我没看错你。」\n小美：「敬你。」",
"effects": [
{"type": "modify_stat", "stat": "mood", "delta": 30},
{"type": "modify_money", "delta": -500},
{"type": "set_flag", "flag_id": "celebration_held", "value": true}
]
}]
auto_close_on_end = true
