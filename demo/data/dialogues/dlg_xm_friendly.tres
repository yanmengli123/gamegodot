[gd_resource type="Resource" script_class="DialogueData" load_steps=2 format=3]

[ext_resource type="Script" path="res://core/resources/dialogue_data.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
dialogue_id = &"dlg_xm_friendly"
first_node = "intro"
nodes = [{
"node_id": "intro",
"speaker": "npc_xiao_mei",
"portrait": "normal",
"text": "你又来啦。今天……不忙吗？",
"choices": [
{"text": "想你了", "next_node": "shy", "condition": "charm >= 50"},
{"text": "找你聊聊天", "next_node": "chat"}
]
}, {
"node_id": "shy",
"speaker": "npc_xiao_mei",
"portrait": "surprised",
"text": "你、你说什么呢……（脸红）",
"effects": [
{"type": "modify_affinity", "npc_id": "npc_xiao_mei", "delta": 8},
{"type": "set_flag", "flag_id": "xm_shy_once", "value": true}
]
}, {
"node_id": "chat",
"speaker": "npc_xiao_mei",
"portrait": "happy",
"text": "嗯……其实我也挺闷的。能跟人说说话，挺好的。",
"effects": [
{"type": "modify_affinity", "npc_id": "npc_xiao_mei", "delta": 5},
{"type": "modify_stat", "stat": "mood", "delta": 5}
]
}]
auto_close_on_end = true
