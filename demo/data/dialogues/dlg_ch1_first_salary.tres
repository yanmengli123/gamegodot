[gd_resource type="Resource" script_class="DialogueData" load_steps=2 format=3]

[ext_resource type="Script" path="res://core/resources/dialogue_data.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
dialogue_id = &"dlg_ch1_first_salary"
first_node = "intro"
nodes = [{
"node_id": "intro",
"speaker": "narrator",
"portrait": "normal",
"text": "第 5 天，傍晚。\n你领到了第一笔工资：¥100。\n李哥拍拍你的肩膀：\n「小子，干得不错。明天继续。」",
"choices": [
{"text": "谢谢李哥！", "next_node": "happy"},
{"text": "（沉默）", "next_node": "quiet"}
]
}, {
"node_id": "happy",
"speaker": "narrator",
"portrait": "normal",
"text": "你心里涌起一种奇异的满足感。\n100 元，在这座城市里不算多，但这是你的 100 元。",
"effects": [
{"type": "modify_money", "delta": 100},
{"type": "set_flag", "flag_id": "first_salary", "value": true},
{"type": "modify_stat", "stat": "mood", "delta": 15}
]
}, {
"node_id": "quiet",
"speaker": "narrator",
"portrait": "normal",
"text": "你低下头看着那 100 块钱，\n说不清是高兴还是难过。",
"effects": [
{"type": "modify_money", "delta": 100},
{"type": "set_flag", "flag_id": "first_salary", "value": true},
{"type": "modify_stat", "stat": "mood", "delta": 5}
]
}]
auto_close_on_end = true
