[gd_resource type="Resource" script_class="DialogueData" load_steps=2 format=3]

[ext_resource type="Script" path="res://core/resources/dialogue_data.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
dialogue_id = &"dlg_xm_first"
first_node = "intro"
nodes = [{
"node_id": "intro",
"speaker": "npc_xiao_mei",
"portrait": "surprised",
"text": "啊……你、你是来上网吗？",
"choices": [
{"text": "是的，开一台", "next_node": "buy", "effect": "cash -= 5"},
{"text": "我随便看看", "next_node": "chat"}
]
}, {
"node_id": "buy",
"speaker": "npc_xiao_mei",
"portrait": "normal",
"text": "好，5 块一小时。3 号机位。",
"effects": [
{"type": "modify_money", "delta": -5},
{"type": "modify_affinity", "npc_id": "npc_xiao_mei", "delta": 1}
]
}, {
"node_id": "chat",
"speaker": "npc_xiao_mei",
"portrait": "normal",
"text": "嗯……这里人不多，挺安静的。",
"effects": [
{"type": "modify_affinity", "npc_id": "npc_xiao_mei", "delta": 2},
{"type": "set_flag", "flag_id": "met_xiao_mei", "value": true}
]
}]
auto_close_on_end = true
