[gd_resource type="Resource" script_class="DialogueData" load_steps=2 format=3]

[ext_resource type="Script" path="res://core/resources/dialogue_data.gd" id="1_dlg"]

[resource]
script = ExtResource("1_dlg")
dialogue_id = &"dlg_ch3_marriage"
first_node = "intro"
nodes = [{
"node_id": "intro",
"speaker": "npc_xiao_mei",
"portrait": "surprised",
"text": "「{player_name}，\n你愿不愿意……\n和我领证？」",
"choices": [
{"text": "愿意！", "next_node": "yes"},
{"text": "我还没准备好", "next_node": "no"}
]
}, {
"node_id": "yes",
"speaker": "npc_xiao_mei",
"portrait": "happy",
"text": "太好了！\n我们下个月去民政局。\n我要穿白色的裙子！",
"effects": [
{"type": "set_flag", "flag_id": "married_xiaomei", "value": true},
{"type": "modify_stat", "stat": "mood", "delta": 30}
]
}, {
"node_id": "no",
"speaker": "npc_xiao_mei",
"portrait": "sad",
"text": "好吧……我等你。",
"effects": [
{"type": "modify_stat", "stat": "mood", "delta": -10}
]
}]
auto_close_on_end = true
